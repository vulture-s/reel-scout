# Reel Scout — Environment Configuration
# Copy to .env and fill in values

# --- Paths ---
# REEL_SCOUT_DATA=./data

# --- VLM ---
# VLM_BACKEND=omlx
# VLM_MODEL=
# OMLX_BASE_URL=http://localhost:8000/v1
# OLLAMA_BASE_URL=http://localhost:11434

# --- LLM ---
# LLM_BACKEND=omlx
# LLM_MODEL=
# OPENCLAW_BASE_URL=http://localhost:18789/v1
# OPENCLAW_MODEL=

# --- Whisper ---
# WHISPER_BACKEND=faster-whisper
# WHISPER_MODEL=large-v3
# Language handling (defaults reproduce prior behavior: auto-detect once, transcribe):
#   WHISPER_LANGUAGE=      # "" = auto-detect; or force e.g. "en" / "zh"
#   WHISPER_TASK=transcribe  # or "translate" to force English output
# Bilingual / code-switching audio (中英對照訪談): whisper large-v3 drifts on long
# files — once it locks onto the opening language it "translates" later speech of the
# OTHER language into the locked one (garbled output). Fix = per-chunk re-detection:
#   WHISPER_MULTILINGUAL=1
#   WHISPER_CHUNK_LENGTH=15
# Verified on a 40-min ZH-host/EN-guest interview: latin-char recovery 56%->90%.
# Leave OFF for single-language short-form (multilingual adds per-chunk detect cost).
# WHISPER_MULTILINGUAL=false
# WHISPER_CHUNK_LENGTH=0

# --- Crawl ---
# IG_COOKIES_FILE=
# RATE_LIMIT_PER_MINUTE=10

# --- Vision ---
# KEYFRAME_STRATEGY=scene
# KEYFRAME_MAX=8

# --- External tools ---
# FFMPEG_BIN=ffmpeg

# --- Speaker Diarization ---
DIARIZE_ENABLED=false
# PYANNOTE_AUTH_TOKEN=  # HuggingFace token (required for pyannote)

# --- Optional ---
# WEBHOOK_URL=
